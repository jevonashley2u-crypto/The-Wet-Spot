# -----------------------------------------------------------------------------
# PRODUCTION DEPLOYMENT SECRETS TEMPLATE
# DO NOT COMMIT ACTUAL .env FILE
# -----------------------------------------------------------------------------

# Supabase (Database & Auth)
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe (Payments & Connect)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CLIENT_ID=ca_... # For Connect

# Sentry (Error Tracking)
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_DSN_BACKEND=https://examplePublicKey@o0.ingest.sentry.io/1

# Vercel Environment (automatically populated by Vercel usually, but good to know)
VERCEL_ENV=production

# Backend Security
API_KEY_SECRET=generate_a_secure_random_string_here
